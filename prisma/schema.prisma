// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── NextAuth Models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  bots          Bot[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── BotFlow Domain Models ──────────────────────────────────────────────────

model Bot {
  id        String   @id @default(cuid())
  userId    String
  name      String
  clientId  String
  botToken  String
  publicKey String
  avatarUrl String?
  status    BotStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  commands      Command[]
  executionLogs ExecutionLog[]

  @@index([userId])
}

model Command {
  id              String       @id @default(cuid())
  botId           String
  name            String       // e.g. "ping"
  description     String
  responseType    ResponseType @default(TEXT)
  responseContent String
  enabled         Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@unique([botId, name])
  @@index([botId])
}

model ExecutionLog {
  id          String         @id @default(cuid())
  botId       String
  commandName String
  guildId     String?
  channelId   String?
  userId      String?
  status      ExecutionStatus
  error       String?
  latencyMs   Int?
  timestamp   DateTime       @default(now())

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@index([botId, timestamp])
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum BotStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum ResponseType {
  TEXT
  EMBED
  DYNAMIC
}

enum ExecutionStatus {
  SUCCESS
  ERROR
  TIMEOUT
}
